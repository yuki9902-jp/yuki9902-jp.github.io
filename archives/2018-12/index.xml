    <item>
      <title>Afternoon Tea</title>
      <link>http://localhost:63371/posts/2018-12-20_afternoon-tea/</link>
      <pubDate>Thu, 20 Dec 2018 15:55:08 +0900</pubDate>
      <guid>http://localhost:63371/posts/2018-12-20_afternoon-tea/</guid>
