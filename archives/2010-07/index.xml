      <pubDate>Fri, 09 Jul 2010 00:07:35 +0900</pubDate>
      <guid>http://localhost:1313/posts/2010-07-09_%E3%82%B3%E3%83%BC%E3%83%89%E3%82%AE%E3%82%A2%E3%82%B9-%E5%8F%8D%E9%80%86%E3%81%AE%E3%83%AB%E3%83%AB%E3%83%BC%E3%82%B7%E3%83%A5/</guid>
